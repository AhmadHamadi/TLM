# SMTP credentials — set in your hosting provider (Vercel/Netlify/etc.) Project Settings → Environment Variables
# Do NOT commit real secrets to the repo.

SMTP_HOST=smtp.clinimedia.ca
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=forms@clinimedia.ca
SMTP_PASS=replace-with-real-password

# Optional overrides
MAIL_FROM=forms@clinimedia.ca
